<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Subsystem Analysis</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    .hidden { display: none; }
    .choice-buttons { margin-top: 15px; }
    .choice-buttons button { margin-right: 10px; }
  </style>
</head>
<body>
  <h1>Subsystem Analysis</h1>

  <div id="subSystemContainer">
    <!-- System Selection -->
    <div class="form-group">
      <label for="systemSelect">Choose System:</label>
      <select id="systemSelect" name="system">
        <option value="">-- Select a System --</option>
        <% systems.forEach(system => { %>
          <option value="<%= system %>"><%= system %></option>
        <% }); %>
      </select>
    </div>

    <!-- Subsystem Selection -->
    <div class="form-group">
      <label for="subSystemSelect">Choose Sub-System:</label>
      <select id="subSystemSelect" name="subsystem">
        <option value="">-- Select a Sub-System --</option>
      </select>
    </div>

    <!-- Image Display -->
    <div id="systemImageContainer" class="hidden">
      <h3>System Image</h3>
      <img id="systemImage" src="" alt="System" style="max-width: 400px;">
    </div>

    <!-- Input Method Choice -->
    <div id="inputChoice" class="choice-buttons hidden">
      <p>How would you like to provide symptoms?</p>
      <button type="button" id="typeSymptomsBtn">Type Symptoms</button>
      <button type="button" id="chooseSymptomsBtn">Choose from List</button>
    </div>

    <!-- Type Symptoms Input -->
    <div id="typeSymptomsContainer" class="hidden">
      <textarea id="typedSymptoms" rows="4" cols="50" placeholder="Type symptoms here..."></textarea>
      <button type="button" id="analyzeTypedSymptoms">Analyze</button>
    </div>

    <!-- Choose Symptoms List -->
    <div id="chooseSymptomsContainer" class="hidden">
      <div id="symptomsList"></div>
      <button type="button" id="analyzeChosenSymptoms">Analyze</button>
    </div>

    <!-- Results -->
    <div id="results" class="hidden">
      <h2>Analysis Results</h2>
      <div id="resultsContent"></div>
    </div>
  </div>

  <script>
    const systemSelect = document.getElementById("systemSelect");
    const subSystemSelect = document.getElementById("subSystemSelect");
    const systemImageContainer = document.getElementById("systemImageContainer");
    const systemImage = document.getElementById("systemImage");

    const inputChoice = document.getElementById("inputChoice");
    const typeSymptomsBtn = document.getElementById("typeSymptomsBtn");
    const chooseSymptomsBtn = document.getElementById("chooseSymptomsBtn");

    const typeSymptomsContainer = document.getElementById("typeSymptomsContainer");
    const chooseSymptomsContainer = document.getElementById("chooseSymptomsContainer");

    const resultsDiv = document.getElementById("results");
    const resultsContent = document.getElementById("resultsContent");

    // --- When system changes, load subsystems ---
    systemSelect.addEventListener("change", async () => {
      const selectedSystem = systemSelect.value;
      subSystemSelect.innerHTML = '<option value="">-- Select a Sub-System --</option>';

      if (!selectedSystem) return;

      try {
        const res = await fetch(`/api/subsystems?system=${encodeURIComponent(selectedSystem)}`);
        const subsystems = await res.json();
        subsystems.forEach(sub => {
          const option = document.createElement("option");
          option.value = sub;
          option.textContent = sub;
          subSystemSelect.appendChild(option);
        });
      } catch(err) {
        console.error(err);
      }
    });

    // --- When subsystem is chosen ---
    subSystemSelect.addEventListener("change", () => {
      if (!subSystemSelect.value) return;
      systemImage.src = `/images/${subSystemSelect.value}.png`;
      systemImageContainer.classList.remove("hidden");
      inputChoice.classList.remove("hidden");
      typeSymptomsContainer.classList.add("hidden");
      chooseSymptomsContainer.classList.add("hidden");
      resultsDiv.classList.add("hidden");
    });

    // --- Input choice buttons ---
    typeSymptomsBtn.addEventListener("click", () => {
      typeSymptomsContainer.classList.remove("hidden");
      chooseSymptomsContainer.classList.add("hidden");
      resultsDiv.classList.add("hidden");
    });

    chooseSymptomsBtn.addEventListener("click", async () => {
      typeSymptomsContainer.classList.add("hidden");
      chooseSymptomsContainer.classList.remove("hidden");
      resultsDiv.classList.add("hidden");

      const selectedSystem = systemSelect.value;
      const selectedSubSystem = subSystemSelect.value;

      const res = await fetch(`/api/symptoms?system=${encodeURIComponent(selectedSystem)}&subsystem=${encodeURIComponent(selectedSubSystem)}`);
      const symptoms = await res.json();

      const symptomsList = document.getElementById("symptomsList");
      symptomsList.innerHTML = "";
      symptoms.forEach(symptom => {
        const div = document.createElement("div");
        div.innerHTML = `<input type="checkbox" value="${symptom}" id="symptom-${symptom}">
                         <label for="symptom-${symptom}">${symptom}</label>`;
        symptomsList.appendChild(div);
      });
    });

    // --- Analyze typed symptoms ---
    document.getElementById("analyzeTypedSymptoms").addEventListener("click", async () => {
      const typed = document.getElementById("typedSymptoms").value.trim();
      if (!typed) return alert("Enter symptoms");

      const res = await fetch('/api/analyze', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ symptoms: typed.split(',').map(s => s.trim()) })
      });
      const data = await res.json();
      showResults(data);
    });

    // --- Analyze chosen symptoms ---
    document.getElementById("analyzeChosenSymptoms").addEventListener("click", async () => {
      const checked = Array.from(document.querySelectorAll("#symptomsList input:checked")).map(cb => cb.value);
      if (checked.length === 0) return alert("Select at least one symptom");

      const res = await fetch('/api/analyze', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ symptoms: checked })
      });
      const data = await res.json();
      showResults(data);
    });

    function showResults(data) {
      resultsDiv.classList.remove("hidden");
      resultsContent.innerHTML = JSON.stringify(data, null, 2);
    }
  </script>
</body>
</html>
