<!DOCTYPE html>
<html lang="en">
  <%- include('includes/head', { title: 'New Password', nonce: nonce }) %>
  <body>
    <%- include('includes/header', { nonce: nonce }) %>
    <main class="d-flex align-items-center justify-content-center" style="min-height: 100vh; background-color: #f5f7fa;">
      <div class="card shadow" style="max-width: 420px; width: 100%; padding: 2rem; border-radius: 10px;">
        <h2 class="mb-4 text-center">Set New Password</h2>
        <% if (errorMessage) { %>
          <div class="alert alert-danger"><%= errorMessage %></div>
        <% } %>
        <% if (successMessage) { %>
          <div class="alert alert-success"><%= successMessage %></div>
        <% } %>
        <form action="/auth/reset-password" method="POST" id="resetForm" novalidate>
          <input type="hidden" name="token" value="<%= token %>">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-3">
            <label for="password" class="form-label">New Password</label>
            <input type="password" class="form-control" id="password" name="password" required minlength="8"
              pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$"
              title="Password must be at least 8 characters and include upper and lower case letters, a number, and a special character.">
            <div class="form-text" id="passwordHelp" style="color: #555;">
              <ul class="mb-0 ps-3" style="font-size: 0.97em; list-style: disc;">
                <li>At least 8 characters</li>
                <li>At least one uppercase letter</li>
                <li>At least one lowercase letter</li>
                <li>At least one number</li>
                <li>At least one special character</li>
              </ul>
            </div>
          </div>
          <div class="mb-3">
            <label for="confirmPassword" class="form-label">Confirm New Password</label>
            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required minlength="8">
          </div>
          <button type="submit" class="btn btn-primary w-100">Reset Password</button>
        </form>
      </div>
    </main>
    <script>
  
      document.getElementById('resetForm').addEventListener('submit', function (e) {
        const pw = document.getElementById('password').value;
        const cpw = document.getElementById('confirmPassword').value;
        if (pw !== cpw) {
          e.preventDefault();
          alert('Passwords do not match.');
        }
      });

      const passwordInput = document.getElementById('password');
      const requirements = [
        { regex: /.{8,}/, selector: 0 }, // 8+ chars
        { regex: /[A-Z]/, selector: 1 }, // uppercase
        { regex: /[a-z]/, selector: 2 }, // lowercase
        { regex: /\d/, selector: 3 },    // number
        { regex: /[\W_]/, selector: 4 }  // special char
      ];
      passwordInput.addEventListener('input', function() {
        const value = passwordInput.value;
        document.querySelectorAll('#passwordHelp li').forEach((li, i) => {
          if (requirements[i].regex.test(value)) {
            li.style.color = 'green';
            li.style.fontWeight = 'bold';
          } else {
            li.style.color = '#555';
            li.style.fontWeight = 'normal';
          }
        });
      });
    </script>
  </body>
</html>
