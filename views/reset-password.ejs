<!DOCTYPE html>
<html lang="en">
  <%- include('includes/head', { title: 'New Password', nonce: nonce }) %>
  <body>
    <%- include('includes/header', { nonce: nonce }) %>
    <main>
  <h1>Set New Password</h1>
  <% if (errorMessage) { %>
    <div class="alert alert-danger"><%= errorMessage %></div>
  <% } %>
  <% if (successMessage) { %>
    <div class="alert alert-success"><%= successMessage %></div>
  <% } %>
 <form action="/auth/reset-password" method="POST">
  <input type="hidden" name="token" value="<%= token %>">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="mb-3">
    <label for="password" class="form-label">New Password</label>
    <input type="password" class="form-control" id="password" name="password" required minlength="8"
      pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$"
      title="Password must be at least 8 characters and include upper and lower case letters, a number, and a special character.">
  </div>
  <div class="mb-3">
    <label for="confirmPassword" class="form-label">Confirm New Password</label>
    <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required minlength="8">
  </div>
  <button type="submit" class="btn btn-primary w-100">Reset Password</button>
</form>

</main>

  </body>
</html>
