<!DOCTYPE html>
<html lang="en">
<meta name="csrf-token" content="<%= csrfToken %>">
<%- include('includes/head', { nonce: nonce, customStyles: '<link rel="stylesheet" href="/styles.folder/calculator.css">' })%> 
<link rel="stylesheet" href="/styles.folder/shared.css">
<link rel="stylesheet" href="/styles.folder/saved-results.css">
<body>
<div class="page-wrapper">
    <%- include('includes/header', { nonce: nonce }) %>

<h2>Your Saved Results</h2>

<div class="record-section">
  <div class="record-buttons">
    <button id="showResultsBtn">VA Disability Results</button>
    <button id="showSecondaryBtn">Secondary Conditions</button>
  </div>

  <!-- VA Disability results -->
  <div id="saved-results" style="display:none;">
    <h3>VA Disability Results</h3>
    <div id="saved-results-cards"></div>
  </div>

  <div id="savedSecondaryContainer" style="display:none;">
     <h3>Secondary Conditions</h3>
    <div id="saved-secondary-cards"></div>
  </div>
</div>

<!-- Include the JS file -->
<script src="/js/savedResults.js" nonce="<%= nonce %>"></script>
<script src="/js/dashboard.js" nonce="<%= nonce %>"></script>

<script nonce="<%= nonce %>">
  // Automatically load saved results when page loads
  document.addEventListener('DOMContentLoaded', () => {
    loadSavedResults();
  });
</script>

  
     <div class="spacer"></div>
    <%- include('includes/footer') %>
</div>

<script src="/js/mobile-drawer.js" nonce="<%= nonce %>"></script>
<script src="/js/index.js" nonce="<%= nonce %>"></script>
</body>
</html>
