<!DOCTYPE html>
<html lang="en">
<meta name="csrf-token" content="<%= csrfToken %>">
<%- include('includes/head', { nonce: nonce, customStyles: '<link rel="stylesheet" href="/styles.folder/calculator.css">' })%> 
<link rel="stylesheet" href="/styles.folder/shared.css">
<link rel="stylesheet" href="/styles.folder/saved-results.css">
<body>
<div class="page-wrapper">
    <%- include('includes/header', { nonce: nonce }) %>

<h2>Your Saved Results</h2>
<div id="saved-results">
  <!-- Saved results will be rendered here by loadSavedResults() -->
</div>

<!-- Include the JS file -->
<script src="/js/savedResults.js" nonce="<%= nonce %>"></script>

<script nonce="<%= nonce %>">
  // Automatically load saved results when page loads
  document.addEventListener('DOMContentLoaded', () => {
    loadSavedResults();
  });
</script>

  
     <div class="spacer"></div>
    <%- include('includes/footer') %>
</div>

<script src="/js/mobile-drawer.js" nonce="<%= nonce %>"></script>
<script src="/js/index.js" nonce="<%= nonce %>"></script>
</body>
</html>
