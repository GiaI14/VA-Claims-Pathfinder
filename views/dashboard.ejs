<!DOCTYPE html>
<html lang="en">
<meta name="csrf-token" content="<%= csrfToken %>">
<%- include('includes/head', { nonce: nonce, customStyles: '<link rel="stylesheet" href="/styles.folder/calculator.css">' })%> 
<link rel="stylesheet" href="/styles.folder/shared.css">
<link rel="stylesheet" href="/styles.folder/saved-results.css">
<body>
<div class="page-wrapper">
    <%- include('includes/header', { nonce: nonce }) %>
<!-- Optional page heading -->
<h2>Your Saved Results</h2>

<!-- Button to toggle VA Disability Results -->
<button id="showResultsBtn">VA Disability Results</button>

<!-- Container for the results -->
<div id="saved-results-container" style="display:none;">
    <!-- Title that shows only when button is pressed -->
    <h2 id="savedResultsTitle" style="display:none;">Your Saved VA Disabilities</h2>

    <!-- Actual cards go here -->
    <div id="saved-results"></div>
</div>

<!-- Include the JS file -->
<script src="/js/savedResults.js" nonce="<%= nonce %>"></script>

<script src="/js/savedResults.js" nonce="<%= nonce %>"></script>

<script nonce="<%= nonce %>">
  // Automatically load saved results when page loads
  document.addEventListener('DOMContentLoaded', () => {
    loadSavedResults();
  });
</script>

  
     <div class="spacer"></div>
    <%- include('includes/footer') %>
</div>

<script src="/js/mobile-drawer.js" nonce="<%= nonce %>"></script>
<script src="/js/index.js" nonce="<%= nonce %>"></script>
</body>
</html>
