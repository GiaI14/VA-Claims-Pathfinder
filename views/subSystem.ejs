<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('includes/head', { title: 'Symptom Analysis', nonce: nonce }) %>
    <link rel="stylesheet" href="styles.folder/possibleDisabilities.css" />
    <link rel="stylesheet" href="styles.folder/subSystem.css" />
  </head>
  <body>
    <div class="page-wrapper">
      <%- include('includes/header', { nonce: nonce }) %>

      <div class="container">
        <h1>Symptom Analysis</h1>
        <input type="hidden" id="csrfToken" value="<%= csrfToken %>" />

        <form id="symptom-form">
          <div id="symptomEntriesContainer">
            <div class="symptom-entry">
              <label>
                System Affected:
                <select class="system-select" required>
                  <option value="">Select a system</option>
                  <% systemsFromServer.forEach(system => { %>
                    <option value="<%= system %>"><%= system %></option>
                  <% }) %>
                </select>
              </label>

              <label>
                Sub-System:
                <select class="sub-system-select" required>
                  <option value="">Select a sub-system</option>
                </select>
              </label>

              <div class="symptom-list"></div>

              <img class="system-image" alt="System Image" style="display:none; cursor:pointer;" />
              <button type="button" class="remove-entry-button">Remove Entry</button>
            </div>
          </div>

          <button type="button" id="addEntryButton">Add Another Entry</button>
          <button id="analyzeButton" type="submit">Analyze Symptoms</button>

          <input type="text" name="honeypot" style="display:none" />
        </form>

        <div id="results"></div>
      </div>

      <%- include('includes/footer') %>
    </div>

    <script src="/js/subSystemAnalysis.js" nonce="<%= nonce %>" defer></script>
  </body>
</html> 
