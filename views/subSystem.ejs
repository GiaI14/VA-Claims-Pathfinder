<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Sub-System Symptom Analysis</title>
</head>
<body>
  <form id="symptomForm">
    <input type="hidden" id="csrfToken" name="_csrf" value="<%= csrfToken %>" />
    
    <div id="symptomEntriesContainer">
      <div class="symptom-entry">
        <label>
          System Affected:
          <select class="system-select" required>
            <option value="">Select a system</option>
            <% systemsFromServer.forEach(system => { %>
              <option value="<%= system %>"><%= system %></option>
            <% }) %>
          </select>
        </label>

        <label>
          Sub-System:
          <select class="sub-system-select" required>
            <option value="">Select a sub-system</option>
            <!-- Sub-systems will be loaded dynamically -->
          </select>
        </label>
        <img class="system-image" alt="System Image" style="display:none; cursor:pointer" />
        <button type="button" class="remove-entry-button">Remove Entry</button>
      </div>
    </div>

    <button type="button" id="addEntryButton">Add Entry</button>
    <button type="submit" id="analyzeButton">Analyze Symptoms</button>
  </form>

  <div id="dynamicSymptomsList"></div>
  <div id="results"></div>

  <script src="/js/subSystemAnalysis.js"></script>
</body>
</html>
