<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Symptom Analysis</title>
  <style>
    /* Layout styling */
    .symptom-entry {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
      align-items: center;
    }

    /* Image styling */
    .system-image {
      max-width: 100px;
      max-height: 100px;
      display: none;
      cursor: zoom-in;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .system-image:hover {
      transform: scale(1.05);
      box-shadow: 0 0 8px rgba(0,0,0,0.3);
    }

    /* Lightbox overlay */
    #image-lightbox {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background-color: rgba(0,0,0,0.8);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 9999;
    }
    #image-lightbox img {
      max-width: 90%;
      max-height: 90%;
      cursor: zoom-out;
      transition: transform 0.2s ease;
    }
  </style>
</head>
<body>
  <h1>Symptom Analysis</h1>

  <div id="symptomEntriesContainer">
    <div class="symptom-entry">
      <select class="body-part">
        <option value="">Select System</option>
        <% systems.forEach(function(system) { %>
          <option value="<%= system.name %>"><%= system.name %></option>
        <% }); %>
      </select>
      <input type="text" placeholder="Symptom Description">
      <img class="system-image" src="" alt="System Image">
      <button type="button" class="remove-entry-button">Remove</button>
    </div>
  </div>

  <button type="button" id="addEntryButton">Add Symptom Entry</button>

  <!-- Lightbox -->
  <div id="image-lightbox">
    <img id="lightbox-img" src="" alt="Large view">
  </div>

  <script nonce="<%= nonce %>">
    const systems = <%- JSON.stringify(systems) %>;

    document.addEventListener('DOMContentLoaded', function() {
      console.log('Symptom Analysis page loaded');

      // Mapping of system names to image files
      const systemImages = {
        "Nervous System": "nervous.jpg",
        "Digestive System": "digestive.jpg",
        "Circulatory System": "circulatory.jpg",
        "Respiratory System": "respiratory.jpg"
        // Add more as needed
      };

      const symptomEntriesContainer = document.getElementById('symptomEntriesContainer');
      const addEntryButton = document.getElementById('addEntryButton');
      const lightbox = document.getElementById('image-lightbox');
      const lightboxImg = document.getElementById('lightbox-img');

      function closeLightbox() {
        lightbox.style.display = 'none';
      }

      // Close lightbox when clicking background or image
      lightbox.addEventListener('click', closeLightbox);
      lightboxImg.addEventListener('click', closeLightbox);

      // Open lightbox when clicking a system image
      symptomEntriesContainer.addEventListener('click', function(e) {
        if (e.target.classList.contains('system-image') && e.target.src) {
          lightboxImg.src = e.target.src;
          lightbox.style.display = 'flex';
        }
      });

      // Show/hide system image when system is selected
      symptomEntriesContainer.addEventListener('change', function(e) {
        if (e.target.classList.contains('body-part')) {
          const selectedSystem = e.target.value;
          const entryDiv = e.target.closest('.symptom-entry');
          const imgEl = entryDiv.querySelector('.system-image');

          if (selectedSystem && systemImages[selectedSystem]) {
            imgEl.src = '/images/' + systemImages[selectedSystem];
            imgEl.style.display = 'block';
          } else {
            imgEl.src = '';
            imgEl.style.display = 'none';
          }
        }
      });

      // Remove entry button
      symptomEntriesContainer.addEventListener('click', function(e) {
        if (e.target.classList.contains('remove-entry-button')) {
          const entries = symptomEntriesContainer.querySelectorAll('.symptom-entry');
          if (entries.length > 1) {
            e.target.closest('.symptom-entry').remove();
          } else {
            alert('You must have at least one symptom entry.');
          }
        }
      });

      // Add new symptom entry
      addEntryButton.addEventListener('click', function() {
        const newEntry = document.createElement('div');
        newEntry.className = 'symptom-entry';
        newEntry.innerHTML = `
          <select class="body-part">
            <option value="">Select System</option>
            ${systems.map(system => `<option value="${system.name}">${system.name}</option>`).join('')}
          </select>
          <input type="text" placeholder="Symptom Description">
          <img class="system-image" src="" alt="System Image">
          <button type="button" class="remove-entry-button">Remove</button>
        `;
        symptomEntriesContainer.appendChild(newEntry);
      });
    });
  </script>
</body>
</html>
