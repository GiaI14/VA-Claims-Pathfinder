<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Disability Finder</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <h1 class="page-title">Disability Finder</h1>

    <!-- Step 1: Choose System -->
    <div class="form-group">
      <label for="systemSelect">Select Body System:</label>
      <select id="systemSelect">
        <option value="">-- Choose System --</option>
        <!-- Populated dynamically -->
      </select>
    </div>

    <!-- Step 2: Choose Sub-System -->
    <div class="form-group">
      <label for="subSystemSelect">Select Sub-System:</label>
      <select id="subSystemSelect" disabled>
        <option value="">-- Choose Sub-System --</option>
        <!-- Populated dynamically -->
      </select>
    </div>

    <!-- Step 3: Show Image -->
    <div id="systemImageContainer" class="image-container">
      <!-- Image inserted dynamically -->
    </div>

    <!-- Step 4: Choose Input Method -->
    <div class="toggle-methods">
      <button id="toggleTextInput" class="toggle-btn active">Type Symptoms</button>
      <button id="toggleListInput" class="toggle-btn">Select Symptoms</button>
    </div>

    <!-- Step 4A: Type Symptoms -->
    <div id="textInputContainer" class="input-method">
      <label for="typedSymptoms">Enter symptoms (comma separated):</label>
      <textarea id="typedSymptoms" placeholder="e.g. fatigue, shortness of breath"></textarea>
    </div>

    <!-- Step 4B: Select Symptoms -->
    <div id="listInputContainer" class="input-method hidden">
      <label for="symptomList">Choose symptoms:</label>
      <div id="symptomList">
        <!-- Symptoms checkboxes populated dynamically -->
      </div>
    </div>

    <!-- Step 5: Analyze -->
    <div class="form-group">
      <button id="analyzeButton" class="analyze-btn">Analyze</button>
    </div>

    <!-- Step 6: Results -->
    <div id="resultsContainer">
      <!-- Results inserted dynamically -->
    </div>
  </div>

  <script src="/js/analysis.js"></script>
</body>
</html>
