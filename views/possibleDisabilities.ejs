<!DOCTYPE html>
<html lang="en">
  <%- include('includes/head', { title: 'Symptom Analysis', nonce: nonce }) %>
  <link rel="stylesheet" href="styles.folder/possibleDisabilities.css" />
  <style>
    /* Image container styling */
    .image-container {
      text-align: center;
      margin: 1em 0;
    }

    #systemImage {
      max-width: 512px;
      max-height: 512px;
      border: 1px solid #ddd;
      display: none;
    }
  </style>
  <body>
    <div class="page-wrapper">
      <%- include('includes/header', { nonce: nonce }) %>

      <div class="container">
        <h1>Symptoms Analysis</h1>
        <input type="hidden" id="csrfToken" value="<%= csrfToken %>" />

        <div id="systemImageContainer" class="image-container">
          <img id="systemImage" src="" alt="Body system" />
        </div>

        <form id="symptom-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <h2>New Symptoms</h2>
          <div id="symptomEntriesContainer">
            <div class="symptom-entry">
              <div class="input-group">
                <label>
                  System Affected:
                  <select class="body-part" required>
                    <option value="">Select a system</option>
                    <% systems.forEach(function(system) { %>
                    <option value="<%= system %>"><%= system %></option>
                    <% }); %>
                  </select>
                </label>
                <label>
                  Symptoms:
                  <input
                    type="text"
                    class="symptoms"
                    placeholder="Enter at least 5 symptoms (comma separated)"
                    required
                  />
                </label>
              </div>
              <button type="button" class="remove-entry-button">Remove Entry</button>
            </div>
          </div>
          <div class="button-row">
            <button type="button" id="addEntryButton">Add Another Entry</button>
          </div>
          <div class="analyze-section">
            <button id="analyzeButton">Analyze Symptoms</button>
          </div>

          <input type="text" name="honeypot" style="display: none" />
        </form>

        <!-- Results Display -->
        <div id="results"></div>
      </div>

      <!-- Scripts -->
      <script src="/js/mobile-drawer.js" nonce="<%= nonce %>"></script>
      <script src="/js/symptomAnalysis.js" nonce="<%= nonce %>" defer></script>

      <script nonce="<%= nonce %>">
        document.addEventListener('DOMContentLoaded', function () {
          console.log('Symptom Analysis page loaded');

          const systemImage = document.getElementById('systemImage');
          const systemImages = {
            'Oral Cavity': '512px-202402_Oral_Cavity.svg.png',
            'Lymphatic System': '512px-2201_Anatomy_of_the_Lymphatic_System.jpg',
            'Circulatory System': '512px-Circulatory_System_en_edited.svg.png',
            'Integumentary System': '512px-Dermatology_-_Integumentary_system_1_--_Smart-Servier.png',
            'Digestive System': '512px-Digestive_system_diagram_en.svg.png',
            'Endocrine System': '512px-Endocrine_English.svg.png',
            'Female Genital System': '512px-Female_genital_system_-_Sagittal_view.svg.png',
            'Orbit Nerves': '512px-Lateral_orbit_nerves_chngd.jpg',
            'Male and Female Genital Organs': '512px-Male_and_female_genital_organs.svg.png',
            'Muscular System': '512px-Muscles_front_and_back-es.png',
            'Respiratory System': '512px-Respiratory_system_complete_fr_simplified.svg.png',
            'Nervous System': '512px-TE-Nervous_system_diagram.svg.png',
            'Auditory System': 'Auditory_System.jpg',
            'Sense Organ': 'Sense-Organ.png',
          };

          // Listen for changes on all current and future .body-part selects inside symptomEntriesContainer
          document
            .getElementById('symptomEntriesContainer')
            .addEventListener('change', function (e) {
              if (e.target.classList.contains('body-part')) {
                const selectedSystem = e.target.value;
                if (systemImages[selectedSystem]) {
                  systemImage.src = '/images/' + systemImages[selectedSystem]; // Adjust path if needed
                  systemImage.style.display = 'block';
                } else {
                  systemImage.style.display = 'none';
                  systemImage.src = '';
                }
              }
            });
        });
      </script>

      <div class="spacer"></div>
      <%- include('includes/footer') %>
    </div>
  </body>
</html>
