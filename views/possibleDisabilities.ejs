<!DOCTYPE html>
<html lang="en">
  <%- include('includes/head', { title: 'Symptom Analysis', nonce: nonce }) %>
  <link rel="stylesheet" href="styles.folder/possibleDisabilities.css" />

  <body>
    <div class="page-wrapper">
      <%- include('includes/header', { nonce: nonce }) %>

      <div class="container">
        <h1>Symptoms Analysis</h1>
        <input type="hidden" id="csrfToken" value="<%= csrfToken %>" />

        <form id="symptom-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <h2>New Symptoms</h2>
          <div id="symptomEntriesContainer">
            <div class="symptom-entry">
              <div class="input-group">
                <label for="selectedSystemInput">
                  System Affected
                </label>
                <!-- Visible input to hold selected system -->
                <input
                  type="text"
                  id="selectedSystemInput"
                  name="selectedSystem"
                  placeholder="Select a system"
                  readonly
                  required
                  style="margin-bottom: 10px; padding: 8px; width: 300px;"
                />

                <div class="custom-dropdown" id="customDropdown">
                  <% systems.forEach(function(system) { %>
                  <div class="dropdown-item" data-system="<%= system %>">
                    <%= system %>
                    <div class="hover-image">
                      <img src="/images/<%= systemImages[system] %>" alt="<%= system %>" />
                    </div>
                  </div>
                  <% }); %>
                </div>

                <label>
                  Symptoms:
                  <input
                    type="text"
                    class="symptoms"
                    placeholder="Enter at least 5 symptoms (comma separated)"
                    required
                  />
                </label>
              </div>

              <button type="button" class="remove-entry-button">Remove Entry</button>
            </div>
          </div>

          <div class="button-row">
            <button type="button" id="addEntryButton">Add Another Entry</button>
          </div>

          <div class="analyze-section">
            <button id="analyzeButton">Analyze Symptoms</button>
          </div>

          <input type="text" name="honeypot" style="display: none" />
        </form>

        <!-- Results Display -->
        <div id="results"></div>
      </div>

      <!-- Styles -->
      <style>
        .custom-dropdown {
          border: 1px solid #ccc;
          width: 300px;
          max-height: 300px;
          overflow-y: auto;
          padding: 0;
          margin: 0;
          user-select: none;
          background: white;
        }

        .dropdown-item {
          padding: 10px;
          position: relative;
          cursor: pointer;
          border-bottom: 1px solid #eee;
          list-style: none;
        }

        .dropdown-item:hover {
          background-color: #f5f5f5;
        }

        .dropdown-item.selected {
          background-color: #d0eaff;
        }

        .hover-image {
          display: none;
          position: absolute;
          left: 100%;
          top: 0;
          z-index: 100;
          width: 200px;
          background-color: white;
          border: 1px solid #ccc;
          box-shadow: 0 0 5px rgba(0, 0, 0, 0.2);
        }

        .dropdown-item:hover .hover-image {
          display: block;
        }

        .hover-image img {
          width: 100%;
          height: auto;
          display: block;
        }
      </style>

      <!-- Scripts -->
      <script src="/js/mobile-drawer.js" nonce="<%= nonce %>"></script>
      <script src="/js/symptomAnalysis.js" nonce="<%= nonce %>" defer></script>

      <script nonce="<%= nonce %>">
        document.addEventListener('DOMContentLoaded', function () {
          console.log('Symptom Analysis page loaded');

          const dropdown = document.getElementById('customDropdown');
          const selectedInput = document.getElementById('selectedSystemInput');

          dropdown.addEventListener('click', function (e) {
            const item = e.target.closest('.dropdown-item');
            if (!item) return;

            const selectedSystem = item.dataset.system;
            selectedInput.value = selectedSystem;

            // Highlight selected item
            document.querySelectorAll('.dropdown-item').forEach(el => {
              el.classList.remove('selected');
            });
            item.classList.add('selected');
          });
        });
      </script>

      <div class="spacer"></div>
      <%- include('includes/footer') %>
    </div>
  </body>
</html>
