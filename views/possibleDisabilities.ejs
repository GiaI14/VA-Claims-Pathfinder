<!DOCTYPE html>
<html lang="en">
  <%- include('includes/head', { title: 'Choose Your Claim Path', nonce: nonce }) %>
  <link rel="stylesheet" href="styles.folder/possibleDisabilities.css" />

  <body>
    <div class="page-wrapper">
      <%- include('includes/header', { nonce: nonce }) %>

      <style>
        .option {
          margin: 10px 0;
          padding: 12px;
          border: 2px solid #1e3a8a;
          border-radius: 12px;
          background: #f9fafb;
          cursor: pointer;
          transition: background 0.3s;
        }
        .option:hover {
          background: #e0e7ff;
        }
        .content {
          display: none;
          margin-top: 10px;
          padding: 10px;
          border-left: 4px solid #1e3a8a;
          background: #f3f4f6;
        }
      </style>

      <h1>Choose Your Claim Path</h1>

      <div class="option" data-target="newClaim">
        ➤ New Claim
        <div id="newClaim" class="content">
          <p>If you’ve never filed before or are filing for a new condition, start here.</p>
        </div>
      </div>

      <div class="option" data-target="supplementalClaim">
        ➤ Supplemental Claim
        <div id="supplementalClaim" class="content">
          <p>If your claim was denied but you have new evidence, this is the right option.</p>
        </div>
      </div>

      <div class="option" data-target="higherReview">
        ➤ Higher-Level Review
        <div id="higherReview" class="content">
          <p>If you disagree with a decision and want a senior reviewer to look at it, choose this.</p>
        </div>
      </div>

      <div class="spacer"></div>

      <%- include('includes/footer') %>
    </div> <!-- closes .page-wrapper -->

    <!-- Scripts -->
    <script src="/js/mobile-drawer.js" nonce="<%= nonce %>"></script>
    <script src="/js/symptomAnalysis.js" nonce="<%= nonce %>" defer></script>

    <!-- FIX: External script with nonce -->
    <script nonce="<%= nonce %>">
      document.addEventListener("DOMContentLoaded", () => {
        const options = document.querySelectorAll(".option");
        options.forEach(option => {
          option.addEventListener("click", () => {
            // hide all
            document.querySelectorAll(".content").forEach(c => c.style.display = "none");
            // show only the clicked one
            const targetId = option.getAttribute("data-target");
            document.getElementById(targetId).style.display = "block";
          });
        });
      });
    </script>
  </body>
</html>
