<!DOCTYPE html>
<html lang="en">
  <%- include('includes/head', { title: 'Reset Password', nonce: nonce }) %>
  <link rel="stylesheet" href="/styles.folder/forgotPassword.css">
  <link rel="stylesheet" href="/styles.folder/shared.css">
  <body>
  <div class="page-wrapper">
    <%- include('includes/header', { nonce: nonce }) %>
    <main>
      <h1>Reset Password</h1>
      <% if (errorMessage) { %>
        <div class="alert alert-danger text-center my-4" role="alert" style="font-weight: 600; font-size: 1.1rem;">
        <%= errorMessage %></div>
      <% } %>
      <% if (successMessage) { %>
       <div class="alert alert-success text-center my-4" role="alert" style="font-weight: 600; font-size: 1.1rem;">
        <%= successMessage %>
        </div>
      <% } %>
      <form action="/auth/forgot-password" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-control">
          <input type="email" id="email" name="email" placeholder="Email" required>
        </div>
        <button class="btn">Send Reset Link</button>
      </form>
    </main>
    <%- include('includes/footer') %>
  </div>
  </body>
</html>
