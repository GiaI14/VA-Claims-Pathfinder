<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('includes/head', { title: 'Symptoms Analysis', nonce: nonce }) %>
  <link rel="stylesheet" href="styles.folder/subSystem.css" />
  <link rel="stylesheet" href="/styles.folder/shared.css">
</head>
<body>
  <div class="page-wrapper">
    <%- include('includes/header', { nonce: nonce }) %>

    <div class="container">
      <h1>Symptom Analysis</h1>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <form id="symptom-form">
        <div id="symptomEntriesContainer">
          <div class="symptom-entry">
            <div class="top-row">
              <label>
                System Affected:
                <select class="system-select" required>
                  <option value="" disabled selected hidden>Select a system</option>
                  <% systemsFromServer.forEach(system => { %>
                    <option value="<%= system %>"><%= system %></option>
                  <% }) %>
                </select>
              </label>

              <label>
                Sub-System:
                <select class="sub-system-select" required>
                  <option value="" disabled selected hidden>Select a sub-system</option>
                </select>
              </label>
             
              <img class="system-image" alt="System Image" style="display:none; cursor:pointer;" />
              </div>

              <div class="middle-row" id="inputMethodContainer" style="display:none; margin-top:15px;">
  <p>Choose Symptom Input Method:</p>
  <label>
    <input type="radio" name="symptomInputMethod" value="typing"> Type Symptoms
  </label>
  <label>
    <input type="radio" name="symptomInputMethod" value="selecting"> Select from List
  </label>
</div>

<div class="symptom-input-section" style="display:none; margin-top:15px;">
  <!-- Typing input -->
  <div id="typingInputContainer" style="display:none;">
    <label for="typedSymptoms">Enter Symptoms (comma separated):</label>
    <input type="text" id="typedSymptoms" class="symptom-text-input" placeholder="e.g. fatigue, headache">
  </div>

  <!-- Checkbox selection -->
  <div id="dynamicSymptomsContainer" style="display:none; margin-top: 20px;">
    <h2>Symptoms for Selected Sub-System</h2>
    <div id="dynamicSymptomsList"></div>
  </div>
</div>


            <div class="bottom-row">
              <button type="button" class="remove-entry-button">Remove Entry</button>
            </div>
          </div>
        </div>

        <div id="dynamicSymptomsContainer" style="margin-top: 20px;">
          <h2>Symptoms for Selected Sub-System</h2>
          <div id="dynamicSymptomsList"></div>
        </div>

        <button id="analyzeButton" type="submit">Analyze Symptoms</button>
        <input type="text" name="honeypot" style="display:none" />
      </form>

      <div id="results"></div>
    </div>

    <div class="spacer"></div>
    <%- include('includes/footer') %>
  </div>

  <script src="/js/subSystemAnalysis.js" nonce="<%= nonce %>" defer></script>
</body>
</html>
