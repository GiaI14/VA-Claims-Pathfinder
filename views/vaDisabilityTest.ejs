<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('includes/head', { title: 'VA Disability Finder', nonce: nonce }) %>
  <link rel="stylesheet" href="/styles.folder/shared.css">
  <link rel="stylesheet" href="/styles.folder/subSystem.css">
  <link rel="stylesheet" href="/styles.folder/shared.css">
</head>
<body>
  <div class="page-wrapper">
    <%- include('includes/header', { nonce: nonce }) %>

    <div class="container">
      <h1>VA Disability Finder</h1>

      <form id="symptom-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div id="symptomEntriesContainer">
          <!-- First entry loaded by default -->
          <div class="symptom-entry">
            <div class="top-row">
              <label>
                System Affected:
                <select class="system-select" required>
                  <option value="" disabled selected hidden>Select a system</option>
                  <% systemsFromServer.forEach(system => { %>
                    <option value="<%= system %>"><%= system %></option>
                  <% }) %>
                </select>
              </label>

              <label>
                Sub-System:
                <select class="sub-system-select" required>
                  <option value="" disabled selected hidden>Select a sub-system</option>
                </select>
              </label>

              <img class="system-image" alt="System Image" style="display:none; cursor:pointer;" />
            </div>

            <div class="input-method bottom-row">
              <label><input type="radio" name="inputMethod0" value="typing"> Type Symptoms</label>
              <label><input type="radio" name="inputMethod0" value="selecting"> Select from List</label>
            </div>

            <input type="text" class="typed-symptoms" placeholder="Enter symptoms separated by commas" style="display:none;">
            <div class="dynamic-symptoms-list" style="display:none;"></div>

            <div class="bottom-row">
              <button type="button" class="remove-entry-button">Remove Entry</button>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button type="button" id="addEntryButton">Add Entry</button>
          <button type="button" id="analyzeButton">Analyze Symptoms</button>
        </div>

        <div id="dynamicSymptomsContainer" style="margin-top:20px;">
          <h2>Symptoms for Selected Sub-System</h2>
          <div id="dynamicSymptomsList"></div>
        </div>

      </form>

      <div id="results"></div>
    </div>

    <div class="spacer"></div>
    <%- include('includes/footer') %>
  </div>

  <input type="hidden" id="csrfToken" value="<%= csrfToken %>">

  <script src="/js/vaDisabilityTest.js" nonce="<%= nonce %>" defer></script>
</body>
</html>
