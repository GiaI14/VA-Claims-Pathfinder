<!DOCTYPE html>
<html lang="en">
<%- include('includes/head', { nonce: nonce, customStyles: '<link rel="stylesheet" href="/styles.folder/calculator.css">' }) %> 
<link rel="stylesheet" href="/styles.folder/shared.css">

<body>
  <div class="page-wrapper">
    <%- include('includes/header', { nonce: nonce }) %>
   
    <div id="compensation-container">
      <h1 class="main-heading" style="text-align: center; margin-top: 60px; font-size: 1.5rem;">
        VA Compensation Estimator
      </h1>

      <div class="three-column-layout">
        <!-- Column 1: Left -->
        <div class="column empty-left">
          <h1>How is VA Compensation Calculated?</h1>
          <p>
            VA disability compensation is determined based on your current VA rating and the number of dependents you have.
            Each dependent can increase your monthly compensation. The VA provides a standard schedule for adding amounts
            for spouses, children, and parents.
          </p>
        </div>

        <!-- Column 2: Center -->
        <div class="column center-content">
          <!-- Current VA Rating Input -->
          <div id="current-rating-container">
            <label for="currentRating">Current VA Rating (%)</label>
            <input type="number" id="currentRating" min="0" max="100" value="0">
          </div>

          <hr>

          <!-- Dependents Section -->
          <button id="toggle-dependents">Add Dependents</button>
          <div class="dependents-center-wrapper">
            <div id="dependents-container" style="display: none;">
              <h2>Dependents</h2>
              <div class="dependents-row">
                <div class="dependent-field" style="flex:0 0 auto;">
                  <label for="spouse">
                    <input type="checkbox" id="spouse"> Spouse?
                  </label>
                </div>
                <div class="parents-field">
                  <label for="numParents" style="margin-right: 8px;">Number of Parents:</label>
                  <select id="numParents">
                    <option value="0">0</option>
                    <option value="1">1</option>
                    <option value="2">2</option>
                  </select>
                </div>
              </div>
              <div class="dependents-row">
                <div class="dependent-field">
                  <label for="childrenUnder18">Number of Children Under 18:</label>
                  <input type="number" id="childrenUnder18" min="0" value="0">
                </div>
                <div class="dependent-field">
                  <label for="childrenOver18">Number of Children Over 18 (in school):</label>
                  <input type="number" id="childrenOver18" min="0" value="0">
                </div>
              </div>
            </div>
          </div>

          <!-- Honeypot Field -->
          <input type="text" name="honeypot" style="display: none;">

          <!-- Results Section -->
          <div id="results-container">
            <h2>Exact VA Rating: <span id="exactRating">0%</span></h2>
            <h2>Rounded VA Rating: <span id="roundedRating">0%</span></h2>
            <h2>Estimated Compensation: <span id="result">$0</span></h2>
          </div>
        </div>

        <!-- Column 3: Right -->
        <div class="column empty-right">
          <h1>VA Compensation Example</h1>
          <p>
            Suppose a veteran has a 70% VA rating with a spouse and one child under 18.<br>
            The base compensation for 70% is $1,500/month.<br>
            Additional spouse allowance: $250<br>
            Additional child allowance: $150<br>
            <b>Total Estimated Compensation:</b> $1,900/month
          </p>
        </div>
      </div>
    </div>

    <!-- Compensation JS -->
    <script src="/js/compensation.js" nonce="<%= nonce %>"></script>

    <%- include('includes/footer') %>
  </div>
</body>
</html>
