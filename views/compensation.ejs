<!DOCTYPE html>
<html lang="en">
<%- include('includes/head', { nonce: nonce, customStyles: '<link rel="stylesheet" href="/styles.folder/calculator.css">' }) %> 
<meta name="csrf-token" content="{{csrfToken}}">
<link rel="stylesheet" href="/styles.folder/shared.css">

<body>
  <div class="page-wrapper">
    <%- include('includes/header', { nonce: nonce }) %>
   
    <div id="disabilities-container">
      <h1 class="main-heading" style="text-align: center; margin-top: 60px; font-size: 1.5rem;">
        VA Disability Rating Calculator
      </h1>

      <div class="three-column-layout">
        <!-- Column 1: Left (empty for layout purposes) -->
        <div class="column empty-left"></div>

        <!-- Column 2: Center -->
        <div class="column center-content">
          <!-- Rating Buttons -->
          <div id="rating-buttons">
            <h3>Select Disability Ratings:</h3>
            <div class="button-grid">
              <% for (let i = 0; i <= 100; i += 10) { %>
                <button class="rating-btn" data-rating="<%= i %>">
                  <%= i %>%
                </button>
              <% } %>
            </div>
          </div>

          <hr>

          <!-- Selected Ratings -->
          <div id="selected-ratings-container">
            <h4>Selected Ratings:</h4>
            <div id="selected-ratings" style="display:flex; gap:10px; flex-wrap:wrap;"></div>
          </div>

          <hr>

          <!-- Current Rating -->
          <div id="ratings-inputs">
            <label>Current Combined Rating: <span id="currentRating">0%</span></label><br><br>
          <p></p>
          </div>
          <hr>

          <!-- Dependents Section -->
          <button id="toggle-dependents">Add Dependents</button>
          <div class="dependents-center-wrapper">
            <div id="dependents-container" style="display:none;">
              <h2>Dependents</h2>
              <div class="dependents-row">
                <div class="dependent-field" style="flex:0 0 auto;">
                <label for="spouse">
                  <input type="checkbox" id="spouse"> Spouse?
                </label>
              </div>
              <div class="parents-field">
                <label for="numParents" style="margin-right: 8px;">Number of Parents:</label>
                <select id="numParents">
                  <option value="0">0</option>
                  <option value="1">1</option>
                  <option value="2">2</option>
                </select>
              </div>
              <div class="dependents-row">
               <div class="dependent-field">
                    <label for="childrenUnder18">Number of Children Under 18:</label>
                    <input type="number" id="childrenUnder18" min="0" value="0">
              </div>
               <div class="dependent-field">
                    <label for="childrenOver18">Number of Children Over 18 (in school):</label>
                    <input type="number" id="childrenOver18" min="0" value="0">
                  </div>
              </div>
            </div>

          <!-- Output Section -->
          <div id="results-container">
            <p>VA Rounded Rating: <span id="vaRoundedRating">0%</span></p>
            <p>Points to Next VA Bracket: <span id="nextBracketPoints">—</span></p>
            <p>Current Compensation: $<span id="currentComp">0.00</span></p>
            <p>Compensation at Next Bracket: $<span id="nextBracketComp">0.00</span></p>
            <p>Pay Difference: $<span id="payDifference">0.00</span></p>
          </div>
        </div>

        <!-- Column 3: Right (empty for layout purposes) -->
        <div class="column empty-right"></div>
      </div>
    </div>

    <script nonce="<%= nonce %>">
  const csrfToken = '<%= csrfToken %>';
</script>
<script src="/js/compensation.js" nonce="<%= nonce %>"></script>

    <%- include('includes/footer') %>
  </div>
</body>
</html>
